{
    "name": "@acusti/uikit",
    "version": "0.0.1",
    "private": true,
    "description": "UI toolkit monorepo containing a React component library, UI utilities, a drag-and-drop library, and more",
    "keywords": [
        "aws",
        "component-library",
        "fetch",
        "isomorphic",
        "node",
        "react",
        "react-component",
        "toolkit",
        "ts",
        "typescript",
        "uikit"
    ],
    "homepage": "https://github.com/acusti/uikit#readme",
    "bugs": {
        "url": "https://github.com/acusti/uikit/issues"
    },
    "license": "Unlicense",
    "author": "andrew patton <andrew@acusti.ca> (https://www.acusti.ca)",
    "repository": {
        "type": "git",
        "url": "https://github.com/acusti/uikit.git"
    },
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "postinstall": "node ./scripts/install-git-hooks.mjs",
        "build": "node ./scripts/run-workspaces.mjs build --exclude @acusti/uikit-docs",
        "buildall": "node ./scripts/run-workspaces.mjs build",
        "dev": "bun run --filter '@acusti/uikit-docs' storybook",
        "format": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore .oxlintrc.json package.json README.md tsconfig.base.json tsconfig.json ./.changeset/ ./packages/ ./packages/docs/.storybook/",
        "format:check": "oxfmt --check --ignore-path .gitignore --ignore-path .oxfmtignore .oxlintrc.json package.json README.md tsconfig.base.json tsconfig.json ./.changeset/ ./packages/ ./packages/docs/.storybook/",
        "lint": "oxlint -c ./.oxlintrc.json --type-aware ./packages/*/src",
        "lintfix": "oxlint -c ./.oxlintrc.json --type-aware --fix-dangerously ./packages/*/src",
        "test": "vitest",
        "tsc": "bun run --workspaces --parallel tsc"
    },
    "dependencies": {
        "@changesets/cli": "^2.29.8"
    },
    "devDependencies": {
        "@babel/core": "^7.28.6",
        "@microsoft/api-extractor": "^7.57.7",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.0.3",
        "@types/react": "^19.2.10",
        "eslint-plugin-perfectionist": "^5.4.0",
        "eslint-plugin-react-compiler": "^19.1.0-0",
        "eslint-plugin-react-hooks": "7.0.1",
        "happy-dom": "^20.4.0",
        "oxfmt": "^0.47.0",
        "oxlint": "^1",
        "oxlint-tsgolint": ">=0.12",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "5.9.2",
        "unplugin-dts": "^1",
        "vite": "^8",
        "vitest": "^4"
    },
    "overrides": {
        "zod-validation-error": "^4.0.2"
    },
    "packageManager": "bun@1.3.9"
}
