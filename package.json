{
    "name": "@acusti/uikit",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "description": "UI toolkit monorepo containing a React component library, UI utilities, a drag-and-drop library, and more",
    "keywords": [
        "react",
        "react-component",
        "component-library",
        "uikit",
        "toolkit",
        "node",
        "fetch",
        "aws",
        "isomorphic",
        "typescript",
        "ts"
    ],
    "scripts": {
        "build": "node ./scripts/run-workspaces.mjs build --exclude @acusti/uikit-docs",
        "buildall": "node ./scripts/run-workspaces.mjs build",
        "dev": "bun run --filter '@acusti/uikit-docs' storybook",
        "format": "prettier --write eslint.config.js package.json README.md tsconfig.json ./.changeset/ ./packages/ ./packages/docs/.storybook/",
        "lint": "eslint './packages/*/src/**/*.{js,jsx,ts,tsx}'",
        "lintfix": "eslint './packages/*/src/**/*.{js,jsx,ts,tsx}' --fix",
        "test": "vitest",
        "tsc": "bun run --workspaces --parallel tsc"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/acusti/uikit.git"
    },
    "author": "andrew patton <andrew@acusti.ca> (https://www.acusti.ca)",
    "license": "Unlicense",
    "bugs": {
        "url": "https://github.com/acusti/uikit/issues"
    },
    "homepage": "https://github.com/acusti/uikit#readme",
    "workspaces": [
        "packages/*"
    ],
    "dependencies": {
        "@changesets/cli": "^2.29.8"
    },
    "overrides": {
        "zod-validation-error": "^4.0.2"
    },
    "devDependencies": {
        "@babel/core": "^7.28.6",
        "@eslint/js": "^9.39.2",
        "@microsoft/api-extractor": "^7.57.7",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.0.3",
        "@types/react": "^19.2.10",
        "@typescript-eslint/eslint-plugin": "^8.48.1",
        "@typescript-eslint/parser": "^8.48.1",
        "@typescript-eslint/types": "^8.48.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-canonical": "^5.1.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.12.1",
        "eslint-plugin-jest-dom": "^5.5.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-markdown": "^5.1.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-perfectionist": "^5.4.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "rc",
        "eslint-plugin-react-hooks": "^7",
        "eslint-plugin-testing-library": "^7.15.4",
        "globals": "^17.0.0",
        "happy-dom": "^20.4.0",
        "prettier": "^3.7.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "5.9.2",
        "unplugin-dts": "^1.0.0-beta.6",
        "vite": "^7.1.10",
        "vitest": "^4"
    },
    "eslintIgnore": [
        "/node_modules",
        "/build",
        "/public"
    ],
    "prettier": {
        "arrowParens": "always",
        "printWidth": 90,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "all",
        "useTabs": false,
        "overrides": [
            {
                "files": [
                    "*.css",
                    "*.scss"
                ],
                "options": {
                    "singleQuote": false
                }
            },
            {
                "files": [
                    "*.md",
                    "*.mdx",
                    "*.markdown"
                ],
                "options": {
                    "printWidth": 75,
                    "proseWrap": "always"
                }
            }
        ]
    },
    "packageManager": "bun@1.3.9"
}
